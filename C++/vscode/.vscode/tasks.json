{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "C/C++: g++.exe 生成活动文件",
      "command": "F:\\MinGW-W64\\13.2.0-rev3\\bin\\g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${workspaceFolder}\\debug\\${fileBasenameNoExtension}.exe",
        "-std=c++23",
        "-fexec-charset=GBK"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": "build",
      "detail": "调试器生成的任务。"
    }
  ],
  "presentation": {
    "echo": true,
    "reveal": "always",
    "focus": true,
    "panel": "new",
    "showReuseMessage": false,
    "clear": false
  }
}
